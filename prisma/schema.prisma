generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum InventoryMovementType {
  CREATED
  ADJUSTMENT
  ORDER_DEDUCTION
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  REJECTED
}

model Product {
  id                 String              @id @default(cuid())
  slug               String              @unique
  sku                String?             @unique
  supplier           String
  originCountry      String
  category           String
  name               String
  price              Int
  previousPrice      Int
  stock              Int                 @default(0)
  minimumStock       Int                 @default(3)
  image              String
  galleryImages      String[]            @default([])
  availability       String
  shortDescription   String
  description        String
  application        String?
  marketFocus        String?
  compatibility      String[]            @default([])
  technicalSpecs     Json?
  featured           Boolean             @default(false)
  active             Boolean             @default(true)
  inventoryMovements InventoryMovement[]
  quotes             Quote[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  company      String?
  phone        String?
  role         UserRole @default(CUSTOMER)
  passwordHash String
  logoUrl      String?
  orders       Order[]
  quotes       Quote[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Order {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  customerName   String
  customerEmail  String
  customerPhone  String?
  company        String?
  trackingNumber String?
  carrier        String?
  notes          String?
  subtotal       Int
  totalItems     Int
  items          OrderItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  image     String
  unitPrice Int
  quantity  Int
  lineTotal Int
  createdAt DateTime @default(now())
}

model Quote {
  id                 String      @id @default(cuid())
  productId          String
  clientId           String
  quantity           Int
  destinationCountry String
  message            String?
  status             QuoteStatus @default(PENDING)
  providerPrice      Int?
  providerNote       String?
  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  client             User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model InventoryMovement {
  id         String                @id @default(cuid())
  productId  String
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       InventoryMovementType
  quantity   Int
  stockAfter Int
  note       String?
  createdAt  DateTime              @default(now())
}
